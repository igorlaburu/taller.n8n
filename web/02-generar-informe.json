          "assignments": [
            {
              "id": "h001",
              "name": "html_informe",
              "value": "=<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Informe del Taller</title>\n  <style>\n    body { font-family: 'Segoe UI', sans-serif; max-width: 800px; margin: 40px auto; padding: 20px; color: #1a1a2e; }\n    h1 { color: #de2315; border-bottom: 3px solid #de2315; padding-bottom: 10px; }\n    h2 { color: #0f3460; margin-top: 30px; }\n    .stats { display: flex; gap: 20px; margin: 20px 0; }\n    .stat-box { background: #f0f4ff; border-left: 4px solid #de2315; padding: 15px 20px; border-radius: 6px; flex: 1; }\n    .stat-box .numero { font-size: 36px; font-weight: bold; color: #de2315; }\n    .stat-box .label { color: #666; font-size: 14px; }\n    .analisis { background: #fafafa; border: 1px solid #eee; padding: 20px; border-radius: 8px; line-height: 1.7; white-space: pre-wrap; }\n    .footer { margin-top: 40px; color: #aaa; font-size: 13px; text-align: center; }\n  </style>\n</head>\n<body>\n  <h1>Informe del Taller — Generado en tiempo real por n8n + IA</h1>\n  <div class=\"stats\">\n    <div class=\"stat-box\">\n      <div class=\"numero\">{{ $('Formatear para OpenAI').item.json.total }}</div>\n      <div class=\"label\">Participantes</div>\n    </div>\n    <div class=\"stat-box\">\n      <div class=\"numero\">{{ $now.setZone('Europe/Madrid').toFormat('HH:mm') }}</div>\n      <div class=\"label\">Hora de generacion</div>\n    </div>\n    <div class=\"stat-box\">\n      <div class=\"numero\">{{ $now.setZone('Europe/Madrid').toFormat('dd/MM/yyyy') }}</div>\n      <div class=\"label\">Fecha</div>\n    </div>\n  </div>\n  <h2>Analisis de la IA</h2>\n  <div class=\"analisis\">{{ $json.text }}</div>\n  <div class=\"footer\">Generado automaticamente por n8n + OpenRouter · Taller de Automatizacion con IA · Gako</div>\n</body>\n</html>",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
