    {
      "parameters": {
        "jsCode": "const respuestas = items[0].json.respuestas;\nconst total = respuestas.length;\n\nif (total === 0) {\n  return [{ json: { texto_para_ia: 'No hay respuestas todavia.', total: 0 } }];\n}\n\nconst sectores = {};\nconst roles = {};\nconst experiencias = {};\nconst procesos = [];\n\nrespuestas.forEach(r => {\n  sectores[r.sector] = (sectores[r.sector] || 0) + 1;\n  roles[r.rol] = (roles[r.rol] || 0) + 1;\n  experiencias[r.experiencia_ia] = (experiencias[r.experiencia_ia] || 0) + 1;\n  if (r.proceso_a_automatizar && r.proceso_a_automatizar !== 'No especificado') {\n    procesos.push(`- ${r.nombre} (${r.rol}): \"${r.proceso_a_automatizar}\"`);\n  }\n});\n\nconst formatearConteos = (obj) =>\n  Object.entries(obj)\n    .sort((a, b) => b[1] - a[1])\n    .map(([k, v]) => `  - ${k}: ${v}`)\n    .join('\\n');\n\nconst textoParaIA = `Analiza esta encuesta de un taller de automatización con IA y n8n. Redacta un informe breve en español (máximo 200 palabras) con este formato exacto:\n\n**Perfil del grupo**\n2-3 frases destacando los datos más relevantes del grupo. Menciona cifras concretas del tipo \"X de cada Y\" o porcentajes cuando sea posible.\n\n**Qué quieren automatizar**\nLista concisa de los procesos mencionados, agrupados por similitud si los hay. Si no hay respuestas, indícalo en una línea.\n\n**Recomendaciones para el taller**\n2 recomendaciones concretas y accionables, basadas en los datos.\n\nUsa **negrita** para resaltar conceptos clave. Sé directo y evita frases genéricas.\n\nDATOS:\nParticipantes: ${total}\n\nSectores:\n${formatearConteos(sectores)}\n\nRoles:\n${formatearConteos(roles)}\n\nExperiencia con IA:\n${formatearConteos(experiencias)}\n\nProcesos a automatizar:\n${procesos.length > 0 ? procesos.join('\\n') : '  (ninguno especificado)'}\n`;\n\nreturn [{ json: { texto_para_ia: textoParaIA, total } }];"
      },
      "id": "ddb74971-caf2-4fde-a8eb-cee95d92a51c",
      "name": "Formatear para OpenAI",
