      "id": "f374e22c-8554-48c2-8b7b-1943e59e84b1",
      "name": "Servir Informe HTML",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1280,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": " const texto = items[0].json.text;                                                                                                                                     \n                                                                                     \n  const html = texto\n    // Títulos con **texto:**\n    .replace(/\\*\\*(.+?):\\*\\*/g, '<strong>$1:</strong>')\n    // Negrita **texto**\n    .replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>')\n    // Saltos de línea dobles → párrafos\n    .replace(/\\n\\n/g, '</p><p>')\n    // Listas con guión\n    .replace(/^- (.+)$/gm, '<li>$1</li>')\n    // Envolver listas en <ul>\n    .replace(/(<li>.*<\\/li>)/gs, '<ul>$1</ul>')\n    // Saltos de línea simples\n    .replace(/\\n/g, '<br>');\n\n  return [{ json: { ...items[0].json, text: '<p>' + html + '</p>' } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        0
      ],
      "id": "6373e5c8-9e0d-42be-82df-893095011e44",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst now = new Date();\nconst lastRun = staticData.generadoEn ? new Date(staticData.generadoEn) : null;\nif (!lastRun || (now - lastRun) >= 120000) {\n  staticData.html = $input.first().json.html_informe;\n  staticData.generadoEn = now.toISOString();\n}\nreturn $input.all();"
      },
